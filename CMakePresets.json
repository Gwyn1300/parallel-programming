{
    "version": 3,
    "configurePresets": [
        {
            "name": "msvc-debug",
            "displayName": "MSVC Debug",
            "description": "MSVC Debug configuration",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc/debug",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "20"
            }
        },
        {
            "name": "msvc-release",
            "displayName": "MSVC Release",
            "description": "MSVC Release configuration",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc/release",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "20"
            }
        },
        {
            "name": "msvc-mpi-debug",
            "displayName": "MSVC MPI Debug",
            "description": "MSVC with MPI Debug configuration",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc/mpi-debug",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "20",
                "MPI_CXX_COMPILER": "C:/Program Files (x86)/Microsoft MPI/bin/mpicxx.exe"
            }
        },
        {
            "name": "ninja-msvc",
            "displayName": "Ninja MSVC",
            "description": "Ninja with MSVC compiler",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_C_COMPILER": "cl.exe"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-msvc-debug",
            "displayName": "Build MSVC Debug",
            "configurePreset": "msvc-debug"
        },
        {
            "name": "build-msvc-release",
            "displayName": "Build MSVC Release",
            "configurePreset": "msvc-release"
        },
        {
            "name": "build-msvc-mpi",
            "displayName": "Build MSVC MPI",
            "configurePreset": "msvc-mpi-debug"
        }
    ]
}